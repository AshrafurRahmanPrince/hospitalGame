// Helper: treat letter key down regardless of shift (lower or upper)
bool isKeyDownChar(char c)
{
    char up = (char)toupper((unsigned char)c);
	// Use GetAsyncKeyState for more reliable, immediate key state checks
	return ((GetAsyncKeyState((int)up) & 0x8000) != 0) || ((GetAsyncKeyState((int)c) & 0x8000) != 0);
}

// Map window (current glut window) coordinates to fixed game coordinates (WIN_W x WIN_H)
void mapWindowToGame(int wx, int wy, int &gx, int &gy)
{
    // Prefer precise client coords via Win32 to handle window decorations and DPI.
    POINT p;
    if (GetCursorPos(&p))
    {
        HWND hwnd = GetForegroundWindow();
        if (hwnd != NULL)
        {
            RECT rc;
            if (GetClientRect(hwnd, &rc))
            {
                // convert screen coords to client coords
                POINT cp = p;
                ScreenToClient(hwnd, &cp);

                int clientW = rc.right - rc.left;
                int clientH = rc.bottom - rc.top;
                if (clientW <= 0 || clientH <= 0) { gx = wx; gy = wy; return; }

                // Map client (top-left origin) to game virtual coords.
                // iGraphics/game uses bottom-left origin, so invert Y here.
                gx = (int)((double)cp.x * WIN_W / clientW);
                gy = WIN_H - (int)((double)cp.y * WIN_H / clientH);
                return;
            }
        }
    }

    // Fallback to GLUT scaling if Win32 path fails
    int wndW = glutGet(GLUT_WINDOW_WIDTH);
    int wndH = glutGet(GLUT_WINDOW_HEIGHT);
    if (wndW <= 0 || wndH <= 0) { gx = wx; gy = wy; return; }
    gx = (int)((double)wx * WIN_W / wndW);
    gy = WIN_H - (int)((double)wy * WIN_H / wndH);
}

// Extracted interaction handling so it can be triggered from both event and polled input
void handleInteract()
{
    if (currentScreen != SCREEN_GAME || gameOver) return;

    double cx = playerX + playerSize / 2.0;
    double cy = playerY + playerSize / 2.0;

    // 1) Objective Checks
    if (currentLevel == 2)
    {
        if (!hasKeycard && sqrt((cx - keyX)*(cx - keyX) + (cy - keyY)*(cy - keyY)) < 40)
        {
            hasKeycard = true;
            strcpy(popupText, "Keycard Collected!");
            popupTimer = 100;
        }
        else if (hasKeycard && !doorUnlocked && sqrt((cx - doorX)*(cx - doorX) + (cy - doorY)*(cy - doorY)) < 50)
        {
            doorUnlocked = true;
            strcpy(popupText, "Door Unlocked");
            popupTimer = 100;
            gameState = STATE_TRANSITION; // Trigger level 3
        }
        else if (!hasKeycard && sqrt((cx - doorX)*(cx - doorX) + (cy - doorY)*(cy - doorY)) < 50)
        {
            strcpy(popupText, "Locked. Need Keycard!");
            popupTimer = 60;
        }
    }
    else if (currentLevel == 3)
    {
        if (!genActive && sqrt((cx - genX)*(cx - genX) + (cy - genY)*(cy - genY)) < 50)
        {
            genActive = true;
            BASE_SPAWN_RATE -= 300; // Generator attracts horde
            strcpy(popupText, "Generator ON! Find Survivor!");
            popupTimer = 150;
        }
        if (genActive && !npcRescued && sqrt((cx - npcX)*(cx - npcX) + (cy - npcY)*(cy - npcY)) < 50)
        {
            npcRescued = true;
            strcpy(popupText, "Survivor Rescued! Escape!");
            popupTimer = 150;
        }
        if (npcRescued && sqrt((cx - doorX)*(cx - doorX) + (cy - doorY)*(cy - doorY)) < 50)
        {
            strcpy(popupText, "YOU SURVIVED ALL ROOMS!");
            popupTimer = 500;
            gameOver = true;
            strcpy(popupText, "VICTORY!");
            popupTimer = 500;
        }
        else if (!npcRescued && sqrt((cx - doorX)*(cx - doorX) + (cy - doorY)*(cy - doorY)) < 50)
        {
            strcpy(popupText, "Must rescue survivor first!");
            popupTimer = 60;
        }
    }

    // 2) Drop Item Checks
    for (int i = 0; i < MAX_ITEMS; i++)
    {
        if (itemActive[i])
        {
            double dist = sqrt((cx - itemX[i])*(cx - itemX[i]) + (cy - itemY[i])*(cy - itemY[i]));
            if (dist < 50) // Interaction radius
            {
                if (itemType[i] == 0) ammo += 10;
                else if (itemType[i] == 1) playerHP = (playerHP + 25 > 100) ? 100 : playerHP + 25;
                itemActive[i] = false;
                break; // Pick up only one item per press
            }
        }
    }
}


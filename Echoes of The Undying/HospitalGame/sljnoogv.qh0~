void iMouse(int button, int state, int mx, int my)
{
    if (button != GLUT_LEFT_BUTTON || state != GLUT_DOWN) return;

    // Map click coords to game space so UI and interactions work when window resized
    int gx, gy;
    mapWindowToGame(mx, my, gx, gy);


    // ================= MENU CLICK =================
    if (currentScreen == SCREEN_MENU)
    {
        if (isInside(gx, gy, btnPlay)) resetGame();
        else if (isInside(gx, gy, btnSettings)) currentScreen = SCREEN_SETTINGS;
        else if (isInside(gx, gy, btnCredits)) currentScreen = SCREEN_CREDITS;
        else if (isInside(gx, gy, btnQuit)) exit(0);
    }
	// ================= SETTINGS CLICK =================
    else if (currentScreen == SCREEN_SETTINGS)
    {
        if (isInside(gx, gy, btnDiffEasy)) currentDifficulty = DIFF_EASY;
        else if (isInside(gx, gy, btnDiffNormal)) currentDifficulty = DIFF_NORMAL;
        else if (isInside(gx, gy, btnDiffHard)) currentDifficulty = DIFF_HARD;
        else if (isInside(gx, gy, btnVolMusicDec) && musicVolume > 0) musicVolume -= 10;
        else if (isInside(gx, gy, btnVolMusicInc) && musicVolume < 100) musicVolume += 10;
        else if (isInside(gx, gy, btnVolSfxDec) && sfxVolume > 0) sfxVolume -= 10;
        else if (isInside(gx, gy, btnVolSfxInc) && sfxVolume < 100) sfxVolume += 10;
        else if (isInside(gx, gy, btnBack)) currentScreen = SCREEN_MENU;
    }
	// ================= CREDITS CLICK =================
    else if (currentScreen == SCREEN_CREDITS)
    {
        if (isInside(gx, gy, btnBack)) currentScreen = SCREEN_MENU;
    }
	// ================= PAUSE CLICK =================
    else if (currentScreen == SCREEN_PAUSE)
    {
        if (isInside(gx, gy, btnPauseResume)) currentScreen = SCREEN_GAME;
        else if (isInside(gx, gy, btnPauseRestart)) resetGame();
        else if (isInside(gx, gy, btnPauseMenu)) currentScreen = SCREEN_MENU;
    }

	// Editor UI clicks (when active) - editor is modal over game
	if (obstacleEditorActive)
	{
		if (isInside(gx, gy, btnEditorAdd))
		{
			editorAdding = true;
			editorTempVx.clear(); editorTempVy.clear();
			return;
		}
		else if (isInside(gx, gy, btnEditorFinish))
		{
			if (editorAdding && editorTempVx.size() >= 3)
			{
				Obstacle o;
				o.vx = editorTempVx;
				o.vy = editorTempVy;
				o.r = 255; o.g = 0; o.b = 0; o.a = 0.3f;
				roomObstacles[currentRoom].push_back(o);
			}
			editorAdding = false;
			editorTempVx.clear(); editorTempVy.clear();
			return;
		}
		else if (isInside(gx, gy, btnEditorDelete))
		{
			if (editorSelected >= 0 && editorSelected < (int)roomObstacles[currentRoom].size())
			{
				roomObstacles[currentRoom].erase(roomObstacles[currentRoom].begin() + editorSelected);
				editorSelected = -1;
			}
			return;
		}
		else if (isInside(gx, gy, btnEditorClear))
		{
			roomObstacles[currentRoom].clear();
			editorSelected = -1;
			return;
		}
		else if (isInside(gx, gy, btnEditorClose))
		{
			obstacleEditorActive = false;
			editorAdding = false;
			editorTempVx.clear(); editorTempVy.clear();
			return;
		}
	}
	// ================= GAME MOUSE (SHOOT) =================
	else if (currentScreen == SCREEN_GAME && !gameOver)
	{
      // If editor active, add points instead of shooting
		if (obstacleEditorActive)
		{
			int gx2, gy2; mapWindowToGame(mx, my, gx2, gy2);
			if (editorAdding)
			{
				editorTempVx.push_back(gx2);
				editorTempVy.push_back(gy2);
			}
			else
			{
				// select obstacle under mouse
				editorSelected = -1;
				for (size_t oi = 0; oi < roomObstacles[currentRoom].size(); oi++)
				{
					if (pointInPolygon(gx2, gy2, roomObstacles[currentRoom][oi]))
					{
						editorSelected = (int)oi; break;
					}
				}
			}
			return;
		}

		if (ammo <= 0) return;
		ammo--;

		// 🔊 Shooting sound pulse (big radius for a short time)
		shootPulseTimer = SHOOT_PULSE_DURATION;

		for (int i = 0; i < MAX_BULLETS; i++)
		{
			if (!bulletActive[i])
			{
				bulletActive[i] = true;
				bulletX[i] = playerX + playerSize / 2;
				bulletY[i] = playerY + playerSize / 2;

				bulletDX[i] = cos(viewAngle);
				bulletDY[i] = sin(viewAngle);
				break;
			}
		}
		return;
	}

    // Death screen clicks
	else if (currentScreen == SCREEN_DEATH)
	{
		if (isInside(gx, gy, btnDeathRetry))
		{
			int savedLevel = currentLevel;
			int savedRoom = currentRoom;
			resetGame();
			currentLevel = savedLevel;
			currentRoom = savedRoom;
			currentScreen = SCREEN_GAME;
			gameOver = false;
			// restart background music
			mciSendString("stop ggsong", NULL, 0, NULL);
			mciSendString("play bgsong repeat", NULL, 0, NULL);
			return;
		}
		else if (isInside(gx, gy, btnDeathMenu))
		{
			currentScreen = SCREEN_MENU;
			gameOver = false;
			// restart menu music
			mciSendString("stop ggsong", NULL, 0, NULL);
			mciSendString("play bgsong repeat", NULL, 0, NULL);
			return;
		}
	}
}


double dist2(double ax, double ay, double bx, double by)
{
	double dx = ax - bx;
	double dy = ay - by;
	return dx*dx + dy*dy;
}

// =====================================================
// OBSTACLE UTILITIES
// =====================================================

bool pointInPolygon(double x, double y, const Obstacle &o)
{
	bool inside = false;
	int n = (int)o.vx.size();
	for (int i = 0, j = n - 1; i < n; j = i++)
	{
		double xi = o.vx[i], yi = o.vy[i];
		double xj = o.vx[j], yj = o.vy[j];

		bool intersect = ((yi > y) != (yj > y)) &&
			(x < (xj - xi) * (y - yi) / (yj - yi + 1e-12) + xi);
		if (intersect) inside = !inside;
	}
	return inside;
}

// segment intersection (helper)
double orient(double ax, double ay, double bx, double by, double cx, double cy)
{
	return (bx - ax) * (cy - ay) - (by - ay) * (cx - ax);
}

bool segIntersectsSeg(double x1,double y1,double x2,double y2,double x3,double y3,double x4,double y4)
{
	double d1 = orient(x1,y1,x2,y2,x3,y3);
	double d2 = orient(x1,y1,x2,y2,x4,y4);
	double d3 = orient(x3,y3,x4,y4,x1,y1);
	double d4 = orient(x3,y3,x4,y4,x2,y2);

	if (((d1 > 0 && d2 < 0) || (d1 < 0 && d2 > 0)) &&
		((d3 > 0 && d4 < 0) || (d3 < 0 && d4 > 0)))
		return true;

	return false;
}

bool rectIntersectsObstacle(double rx, double ry, double rw, double rh, const Obstacle &o)
{
	// Rectangle corners
	double rx1 = rx, ry1 = ry;
	double rx2 = rx + rw, ry2 = ry;
	double rx3 = rx + rw, ry3 = ry + rh;
	double rx4 = rx, ry4 = ry + rh;

	// 1) any corner inside polygon
	if (pointInPolygon(rx1, ry1, o)) return true;
	if (pointInPolygon(rx2, ry2, o)) return true;
	if (pointInPolygon(rx3, ry3, o)) return true;
	if (pointInPolygon(rx4, ry4, o)) return true;

	// 2) any polygon edge intersects any rectangle edge
	int n = (int)o.vx.size();
	for (int i = 0; i < n; i++)
	{
		int j = (i + 1) % n;
		double px1 = o.vx[i], py1 = o.vy[i];
		double px2 = o.vx[j], py2 = o.vy[j];

		if (segIntersectsSeg(px1,py1,px2,py2,rx1,ry1,rx2,ry2)) return true;
		if (segIntersectsSeg(px1,py1,px2,py2,rx2,ry2,rx3,ry3)) return true;
		if (segIntersectsSeg(px1,py1,px2,py2,rx3,ry3,rx4,ry4)) return true;
		if (segIntersectsSeg(px1,py1,px2,py2,rx4,ry4,rx1,ry1)) return true;
	}

	return false;
}

// Circle vs polygon collision: smoother for round entities
double sqr(double x) { return x*x; }

// distance squared from point c to segment a-b
double dist2PointSegment(double px, double py, double ax, double ay, double bx, double by)
{
	double vx = bx - ax;
	double vy = by - ay;
	double wx = px - ax;
	double wy = py - ay;

	double c1 = vx*wx + vy*wy;
	if (c1 <= 0) return sqr(px - ax) + sqr(py - ay);

	double c2 = vx*vx + vy*vy;
	if (c2 <= c1) return sqr(px - bx) + sqr(py - by);

	double t = c1 / c2;
	double projx = ax + t * vx;
	double projy = ay + t * vy;
	return sqr(px - projx) + sqr(py - projy);
}

bool circleIntersectsObstacle(double cx, double cy, double cr, const Obstacle &o)
{
	// if center inside polygon -> intersects
	if (pointInPolygon(cx, cy, o)) return true;

	int n = (int)o.vx.size();
	double r2 = cr*cr;
	for (int i = 0; i < n; i++)
	{
		int j = (i + 1) % n;
		double ax = o.vx[i], ay = o.vy[i];
		double bx = o.vx[j], by = o.vy[j];

		// if distance from center to segment <= r -> intersects
		if (dist2PointSegment(cx, cy, ax, ay, bx, by) <= r2) return true;

		// optional: check vertices
		if (sqr(cx - ax) + sqr(cy - ay) <= r2) return true;
		if (sqr(cx - bx) + sqr(cy - by) <= r2) return true;
	}

	return false;
}

bool circleIntersectsAnyObstacle(double cx, double cy, double cr)
{
	if (roomObstacles.size() <= (size_t)currentRoom) return false;
	for (const auto &o : roomObstacles[currentRoom])
	{
		if (circleIntersectsObstacle(cx, cy, cr, o)) return true;
	}
	return false;
}

// Find nearest free player position (top-left coords) starting from given px,py
bool findFreePlayerPosition(int startX, int startY, int &outX, int &outY)
{
	double pr = playerSize * 0.5;
	double startCX = startX + pr;
	double startCY = startY + pr;

	// if starting position is already free
	if (!circleIntersectsAnyObstacle(startCX, startCY, pr))
	{
		outX = startX; outY = startY; return true;
	}

	const int maxR = 400;
	const int step = 5;
	for (int r = step; r <= maxR; r += step)
	{
		for (int a = 0; a < 360; a += 36)
		{
			double ang = a * (3.14159265358979323846 / 180.0);
			double cx = startCX + r * cos(ang);
			double cy = startCY + r * sin(ang);

			// convert to top-left and clamp to bounds
			int tx = (int)(cx - pr);
			int ty = (int)(cy - pr);
			if (tx < 0) tx = 0;
			if (ty < 0) ty = 0;
			if (tx + playerSize > WIN_W) tx = WIN_W - playerSize;
			if (ty + playerSize > WIN_H) ty = WIN_H - playerSize;

			double tcx = tx + pr;
			double tcy = ty + pr;

			if (!circleIntersectsAnyObstacle(tcx, tcy, pr))
			{
				outX = tx; outY = ty; return true;
			}
		}
	}

	return false;
}

void ensurePlayerNotInObstacle()
{
	int nx, ny;
	if (findFreePlayerPosition(playerX, playerY, nx, ny))
	{
		playerX = nx; playerY = ny;
	}
	// otherwise leave as-is (no free spot found)
}

void drawObstacles()
{
    if (roomObstacles.size() <= (size_t)currentRoom) return;
	for (const auto &o : roomObstacles[currentRoom])
	{
		glEnable(GL_BLEND);
		glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
		glColor4f(o.r / 255.0f, o.g / 255.0f, o.b / 255.0f, o.a);
		glBegin(GL_POLYGON);
		for (size_t i = 0; i < o.vx.size(); i++)
			glVertex2d(o.vx[i], o.vy[i]);
		glEnd();

		// outline
		glColor4f(1, 0, 0, o.a);
		glBegin(GL_LINE_LOOP);
		for (size_t i = 0; i < o.vx.size(); i++)
			glVertex2d(o.vx[i], o.vy[i]);
		glEnd();

		glDisable(GL_BLEND);
	}
}

void makeSoundEvent(int sx, int sy, int radius)
{
	int r2 = radius * radius;

	for (int i = 0; i < zombiesSpawned; i++)
	{
		if (!zombieAlive[i]) continue;

		if (dist2(zombieX[i], zombieY[i], sx, sy) <= r2)
		{
			zState[i] = Z_INVESTIGATE;
			hearX[i] = sx;
			hearY[i] = sy;
			hearTimer[i] = 80; // how long they stay interested (~1.6s if 20ms update)
		}
	}
}

void moveZombieToward(int i, double tx, double ty)
{
	double dx = tx - zombieX[i];
	double dy = ty - zombieY[i];

	double d = sqrt(dx*dx + dy*dy);
	if (d > 0.001)
	{
        // compute velocity vector (magnitude = speed)
        double vx = (dx / d) * zombieSpeed[i];
        double vy = (dy / d) * zombieSpeed[i];

        // apply movement
        zombieX[i] += vx;
        zombieY[i] += vy;

        // store velocity for facing
        zombieDX[i] = vx;
        zombieDY[i] = vy;

        // update facing angle based on velocity
        zombieAngle[i] = atan2(zombieDY[i], zombieDX[i]);
	}
}

void updateZombieAI()
{
	for (int i = 0; i < zombiesSpawned; i++)
	{
		if (!zombieAlive[i]) continue;

		if (zState[i] == Z_INVESTIGATE)
		{
			// move to last heard position
			moveZombieToward(i, hearX[i], hearY[i]);

			// reduce interest timer
			hearTimer[i]--;
			if (hearTimer[i] <= 0)
			{
				zState[i] = Z_WANDER;
				wanderTimer[i] = 0; // force new wander target
			}
		}
		else // Z_WANDER
		{
			wanderTimer[i]--;
			if (wanderTimer[i] <= 0)
			{
				// pick random point in the map
				wanderTX[i] = rand() % WIN_W;
				wanderTY[i] = rand() % WIN_H;
				wanderTimer[i] = 100 + (rand() % 120); // wander for a bit
			}

			moveZombieToward(i, wanderTX[i], wanderTY[i]);
		}
	}
}



// =====================================================
// UPDATE
// =====================================================
void fixedUpdate()
{
    // Poll for certain keys (edge-detect) so event callbacks are not the only
    // way to trigger important actions (ESC pause, interact, reload, restart)
    static bool prevEsc = false, prevE = false, prevQ = false, prevR = false, prevB = false;

    bool escDown = (GetAsyncKeyState(VK_ESCAPE) & 0x8000) != 0;
    if (escDown && !prevEsc)
    {
        if (currentScreen == SCREEN_GAME) currentScreen = SCREEN_PAUSE;
        else if (currentScreen == SCREEN_PAUSE) currentScreen = SCREEN_GAME;
    }
    prevEsc = escDown;

    bool eDown = (GetAsyncKeyState('E') & 0x8000) != 0;
    if (eDown && !prevE) handleInteract();
    prevE = eDown;

    bool qDown = (GetAsyncKeyState('Q') & 0x8000) != 0;
    if (qDown && !prevQ && currentScreen == SCREEN_GAME && !gameOver) ammo = maxAmmo;
    prevQ = qDown;

    bool rDown = (GetAsyncKeyState('R') & 0x8000) != 0;
    if (rDown && !prevR)
    {
        // R key no longer restarts; death screen buttons handle restart/menu
    }
    prevR = rDown;

    bool bDown = (GetAsyncKeyState('B') & 0x8000) != 0;
    if (bDown && !prevB)
    {
        if (currentScreen == SCREEN_SETTINGS || currentScreen == SCREEN_CREDITS) currentScreen = SCREEN_MENU;
    }
    prevB = bDown;

    if (currentScreen != SCREEN_GAME) return;

	// If game over, do not poll R to restart; display death screen overlay handled in iDraw
	if (gameOver)
	{
		return;
	}

	// ================= PROGRESSION TIMER & SPAWNING =================
	if (gameState == STATE_PLAYING && !gameOver)
	{
		if (damageFlashTimer > 0) damageFlashTimer--;
		
		framesSurvived++;
		
		int winTarget = 60; // Level 1 is 60s
		if (currentLevel == 2) winTarget = 300; // Objective based, not strictly time based
		if (currentLevel >= 3) winTarget = 300; // Objective based
		
		// Sub-Level Wave Escalation
		if (framesSurvived % (WAVE_INTERVAL * 100) == 0)
		{
			waveNumber++;

			BASE_SPAWN_RATE -= 150;
			if (BASE_SPAWN_RATE < 200) BASE_SPAWN_RATE = 200;

			// ✅ AFTER 3 WAVES → CHANGE ROOM
			if (waveNumber == 4)
			{
				gameState = STATE_TRANSITION;
			}
		}
		
		// Custom Spawn Rate Logic (Replacement for fixed 1000ms iSetTimer)
		// Because fixedUpdate ticks ~10ms, BASE_SPAWN_RATE/10 gives ticks needed.
		spawnTimerCounter++;
		if (spawnTimerCounter >= (BASE_SPAWN_RATE / 10))
		{
			spawnZombie();
			spawnTimerCounter = 0;
		}

	


	}

	// ================= TRANSITION FADE =================
	if (gameState == STATE_TRANSITION)
	{
		fadeAlpha += 5;

		if (fadeAlpha >= 255)
		{
			//currentLevel++;
			currentRoom++;

			if (currentRoom >= TOTAL_ROOMS)
			{
				gameOver = true;   // All rooms finished
				return;
			}
			zombiesKilled = 0;
			zombiesSpawned = 0;
			framesSurvived = 0;
			waveNumber = 1;
			BASE_SPAWN_RATE = 1000;
			
			if (currentLevel > 3) currentLevel = 3; // Cap at Lv3 for now

			for (int i = 0; i < ZOMBIE_COUNT; i++)
				zombieAlive[i] = false;

			playerX = 200;
			playerY = 200;

			gameState = STATE_PLAYING;
			spawnZombie(); // first zombie
			fadeAlpha = 0; // reset fade immediately
		}
		return;
	}

	// ----- STRICT CONTROLS -----
	bool shiftHeld = ((GetAsyncKeyState(VK_LSHIFT) & 0x8000) != 0) || ((GetAsyncKeyState(VK_RSHIFT) & 0x8000) != 0);
	bool wWalk = (!shiftHeld) && isKeyDownChar('w');
	bool aWalk = (!shiftHeld) && isKeyDownChar('a');
	bool sWalk = (!shiftHeld) && isKeyDownChar('s');
	bool dWalk = (!shiftHeld) && isKeyDownChar('d');

	bool wRun = (shiftHeld) && isKeyDownChar('w');
	bool aRun = (shiftHeld) && isKeyDownChar('a');
	bool sRun = (shiftHeld) && isKeyDownChar('s');
	bool dRun = (shiftHeld) && isKeyDownChar('d');

    bool up = ((GetAsyncKeyState(VK_UP) & 0x8000) != 0);
	bool down = ((GetAsyncKeyState(VK_DOWN) & 0x8000) != 0);
	bool left = ((GetAsyncKeyState(VK_LEFT) & 0x8000) != 0);
	bool right = ((GetAsyncKeyState(VK_RIGHT) & 0x8000) != 0);

	double dx = 0;
	double dy = 0;

	// WALK/RUN Vectors
	if (wWalk || up) dy += 1;
	if (sWalk || down) dy -= 1;
	if (aWalk || left) dx -= 1;
	if (dWalk || right) dx += 1;

	if (wRun) dy += 1;
	if (sRun) dy -= 1;
	if (aRun) dx -= 1;
	if (dRun) dx += 1;

	// Normalize diagonal movement
	if (dx != 0 && dy != 0)
	{
		double length = sqrt(dx * dx + dy * dy);
		dx /= length;
		dy /= length;
	}

    // Running is triggered by WASD + Shift (not arrow keys)
    isRunning = ((wRun || aRun || sRun || dRun) && playerStamina > 0);
	
	if (isRunning)
	{
		playerStamina -= STAMINA_DRAIN;
		if (playerStamina < 0) playerStamina = 0;
	}
	else
	{
		playerStamina += STAMINA_REGEN;
		if (playerStamina > MAX_STAMINA) playerStamina = MAX_STAMINA;
	}
	
	int currentSpeed = isRunning ? PLAYER_SPEED_RUN : PLAYER_SPEED_WALK;
	if (dx == 0 && dy == 0) currentSpeed = 0;

    // apply tentative movement and check collisions with obstacles
	int deltaX = (int)(dx * currentSpeed);
	int deltaY = (int)(dy * currentSpeed);

	// Proposed positions
	int tryX = playerX + deltaX;
	int tryY = playerY + deltaY;

	// clamp proposed to bounds
	if (tryX < 0) tryX = 0;
	if (tryY < 0) tryY = 0;
	if (tryX + playerSize > WIN_W) tryX = WIN_W - playerSize;
	if (tryY + playerSize > WIN_H) tryY = WIN_H - playerSize;

    // Player represented as circle for collision tests
	double pr = playerSize * 0.5;
	double tryCX = tryX + pr;
	double tryCY = tryY + pr;

	// If combined move doesn't collide, apply it.
	if (!circleIntersectsAnyObstacle(tryCX, tryCY, pr))
	{
		playerX = tryX;
		playerY = tryY;
	}
	else
	{
		// Otherwise, attempt axis-aligned sliding: try X-only and Y-only moves.
		int tryXOnly = playerX + deltaX;
		int tryYOnly = playerY + deltaY;

		// clamp
		if (tryXOnly < 0) tryXOnly = 0;
		if (tryXOnly + playerSize > WIN_W) tryXOnly = WIN_W - playerSize;
		if (tryYOnly < 0) tryYOnly = 0;
		if (tryYOnly + playerSize > WIN_H) tryYOnly = WIN_H - playerSize;

		double tryCXOnly = tryXOnly + pr;
		double tryCYOnly = tryYOnly + pr;

		bool moved = false;

		// Prefer X movement first if both inputs present; this gives intuitive sliding.
		if (deltaX != 0 && !circleIntersectsAnyObstacle(tryCXOnly, playerY + pr, pr))
		{
			playerX = tryXOnly;
			moved = true;
		}

		if (deltaY != 0 && !circleIntersectsAnyObstacle(playerX + pr, tryCYOnly, pr))
		{
			playerY = tryYOnly;
			moved = true;
		}

		// If neither axis worked but one of them alone would work, try the other order
		if (!moved)
		{
			if (deltaY != 0 && !circleIntersectsAnyObstacle(playerX + pr, tryCYOnly, pr))
			{
				playerY = tryYOnly;
			}
			else if (deltaX != 0 && !circleIntersectsAnyObstacle(tryCXOnly, playerY + pr, pr))
			{
				playerX = tryXOnly;
			}
		}
	}

	// ---------------------------
	// Character animation (time-based)
	// fixedUpdate runs every 10ms, so increment timer by 10 each tick when moving
	if (dx != 0 || dy != 0)
	{
		charFrameTimerMs += 10; // fixedUpdate tick interval
		if (charFrameTimerMs >= CHAR_FRAME_INTERVAL_MS)
		{
			charFrameTimerMs = 0;
			charFrame = (charFrame + 1) % 6;
		}
	}
	else
	{
		charFrameTimerMs = 0;
		charFrame = 0;
	}


	// --------------------------------
	// 🔊 SOUND SYSTEM
	// --------------------------------

	bool walkingNow = (dx != 0 || dy != 0) && !isRunning;

	currentSoundRadius = 0;

	// FOOTSTEP PULSE logic
	// Fixed physics runs roughly every 10ms (100FPS). A footstep pulse every 30 frames is ~0.3s.
	static int footstepTimer = 0;
	if (walkingNow || isRunning)
	{
		footstepTimer++;
		if (footstepTimer > 30) // Only emit sound periodically (steps)
		{
			footstepTimer = 0;
			if (isRunning) currentSoundRadius = runRadius;
			else if (walkingNow) currentSoundRadius = walkRadius;
		}
	}
	else
	{
		footstepTimer = 0;
	}

	if (currentSoundRadius > 0)
	{
		makeSoundEvent(playerX + playerSize / 2,
			playerY + playerSize / 2,
			currentSoundRadius);
	}

	// Shooting pulse
	if (shootPulseTimer > 0)
	{
		shootPulseTimer--;
		makeSoundEvent(playerX + playerSize / 2,
			playerY + playerSize / 2,
			shootRadius);
	}

	// --------------------------------

	// keep inside window
	if (playerX < 0) playerX = 0;
	if (playerY < 0) playerY = 0;
	if (playerX + playerSize > WIN_W) playerX = WIN_W - playerSize;
	if (playerY + playerSize > WIN_H) playerY = WIN_H - playerSize;

	score++;

	// --------------------------------
	// BULLETS
	// --------------------------------

	for (int i = 0; i < MAX_BULLETS; i++)
	{
		if (!bulletActive[i]) continue;

		bulletX[i] += (int)(bulletDX[i] * bulletSpeed);
		bulletY[i] += (int)(bulletDY[i] * bulletSpeed);

		if (bulletX[i] < 0 || bulletX[i] > WIN_W ||
			bulletY[i] < 0 || bulletY[i] > WIN_H)
			bulletActive[i] = false;
	}

	// Bullet -> Zombie
	for (int i = 0; i < MAX_BULLETS; i++)
	{
		if (!bulletActive[i]) continue;

		for (int j = 0; j < zombiesSpawned; j++)
		{
			if (!zombieAlive[j]) continue;

			bool hitX = bulletX[i] > zombieX[j] &&
				bulletX[i] < zombieX[j] + zombieSize[j];
			bool hitY = bulletY[i] > zombieY[j] &&
				bulletY[i] < zombieY[j] + zombieSize[j];

			if (hitX && hitY)
			{
				zombieHP[j] -= 50;
				bulletActive[i] = false;

			/*	if (zombieHP[j] <= 0)
				{
					zombieAlive[j] = false;
					score += 10;
				}*/
				if (zombieHP[j] <= 0)
				{
					zombieAlive[j] = false;
					score += 10;
					zombiesKilled++;   // count kill
					
					// 20% Item Drop Chance
					if (rand() % 100 < 20)
					{
						for(int k=0; k < MAX_ITEMS; k++)
						{
							if (!itemActive[k])
							{
								itemActive[k] = true;
								itemX[k] = zombieX[j];
								itemY[k] = zombieY[j];
								itemType[k] = rand() % 2; // 0=Ammo, 1=Medkit
								break;
							}
						}
					}
				}

				break;
			}
		}
	}

	// --------------------------------
	// 🧠 ZOMBIE AI UPDATE
	// --------------------------------

    // update AI after movement logic but ensure zombies don't walk into obstacles
	// modify moveZombieToward to check obstacles: we'll emulate by clamping movement if next step collides
	for (int zi = 0; zi < zombiesSpawned; zi++)
	{
		if (!zombieAlive[zi]) continue;
		// compute next step toward current target depending on state
		double tx = (zState[zi] == Z_INVESTIGATE) ? hearX[zi] : wanderTX[zi];
		double ty = (zState[zi] == Z_INVESTIGATE) ? hearY[zi] : wanderTY[zi];

		double dxz = tx - zombieX[zi];
		double dyz = ty - zombieY[zi];
		double dz = sqrt(dxz*dxz + dyz*dyz);
		if (dz > 0.001)
		{
			double vx = (dxz / dz) * zombieSpeed[zi];
			double vy = (dyz / dz) * zombieSpeed[zi];

            double nextX = zombieX[zi] + vx;
			double nextY = zombieY[zi] + vy;

			// zombie as circle (center)
			double zr = zombieSize[zi] * 0.5;
			double nextCX = nextX + zr;
			double nextCY = nextY + zr;

			if (!circleIntersectsAnyObstacle(nextCX, nextCY, zr))
			{
				zombieX[zi] = nextX;
				zombieY[zi] = nextY;
				zombieDX[zi] = vx;
				zombieDY[zi] = vy;
				zombieAngle[zi] = atan2(zombieDY[zi], zombieDX[zi]);
			}
			else
			{
				// attempt sliding for zombies: try X-only then Y-only
				double tryXOnly = zombieX[zi] + vx;
				double tryYOnly = zombieY[zi] + vy;
				double tryCXOnly = tryXOnly + zr;
				double tryCYOnly = tryYOnly + zr;

				bool movedZ = false;
				if (!circleIntersectsAnyObstacle(tryCXOnly, zombieY[zi] + zr, zr))
				{
					zombieX[zi] = tryXOnly;
					movedZ = true;
				}
				if (!movedZ && !circleIntersectsAnyObstacle(zombieX[zi] + zr, tryCYOnly, zr))
				{
					zombieY[zi] = tryYOnly;
					movedZ = true;
				}

				if (!movedZ)
				{
					if (zState[zi] == Z_INVESTIGATE)
					{
						hearTimer[zi] = 0;
					}
					else
					{
						wanderTimer[zi] = 0;
					}
				}
				else
				{
					// update facing based on last movement
					zombieDX[zi] = 0; zombieDY[zi] = 0; // will be set next tick
				}
			}
		}
	}

	// call updateZombieAI to manage timers and states (movement handled above)
	updateZombieAI();

	// --------------------------------
	// ZOMBIE DAMAGE
	// --------------------------------

	for (int i = 0; i < zombiesSpawned; i++)
	{
		if (!zombieAlive[i]) continue;

		bool collisionX =
			playerX < zombieX[i] + zombieSize[i] &&
			playerX + playerSize > zombieX[i];

		bool collisionY =
			playerY < zombieY[i] + zombieSize[i] &&
			playerY + playerSize > zombieY[i];

		if (collisionX && collisionY)
		{
			playerHP--;
			damageFlashTimer = 10;

			if (playerHP <= 0)
			{
            gameOver = true;
				mciSendString("stop bgsong", NULL, 0, NULL);
				mciSendString("play ggsong", NULL, 0, NULL);
           // switch to death screen
			currentScreen = SCREEN_DEATH;
			}
		}
	}

	// ================= LEVEL COMPLETE CHECK =================
	/*if (currentLevel == 1 && zombiesKilled >= ZOMBIE_COUNT)
	{
		gameState = STATE_LEVEL_CLEAR;
		transitionTimer = 200;   // 2 seconds (if update is 10ms)
	}*/

	// ================= LEVEL COMPLETE CHECK =================
	// Handled actively in framesSurvived tick now

}


// =====================================================
// KEYBOARD (RESTART)
// =====================================================
void iKeyboard(unsigned char key)
{
	// Back button shortcuts
	if ((key == 'b' || key == 'B') && (currentScreen == SCREEN_SETTINGS || currentScreen == SCREEN_CREDITS))
	{
		currentScreen = SCREEN_MENU;
		return;
	}

    // ITEM PICKUP & OBJECTIVE INTERACT (delegated)
    if (key == 'e' || key == 'E') handleInteract();

	// PAUSE (ESC key is ASCII 27)
	if (key == 27)
	{
		if (currentScreen == SCREEN_GAME) currentScreen = SCREEN_PAUSE;
		else if (currentScreen == SCREEN_PAUSE) currentScreen = SCREEN_GAME;
	}

	// Single press reload fix
	if ((key == 'q' || key == 'Q') && currentScreen == SCREEN_GAME && !gameOver)
	{
		ammo = maxAmmo;
	}

	// Toggle obstacle editor with 'O' while in game
	if ((key == 'o' || key == 'O') && currentScreen == SCREEN_GAME)
	{
		obstacleEditorActive = !obstacleEditorActive;
		// clear temporary state when closing
		if (!obstacleEditorActive) { editorAdding = false; editorTempVx.clear(); editorTempVy.clear(); editorSelected = -1; }
	}

	// R key no longer restarts when dead; death screen buttons handle restart/menu
}


	// Room 4
	Obstacle r4_1;
	r4_1.vx = {40, 120, 100, 20};
	r4_1.vy = {40, 60, 120, 100};
	r4_1.r = 255; r4_1.g = 0; r4_1.b = 0; r4_1.a = 0.3f;
	roomObstacles[4].push_back(r4_1);

	// Ensure initial player position is not inside an obstacle
	ensurePlayerNotInObstacle();

	// timers
	// iSetTimer(1000, spawnZombie); -> Disabled entirely. Dynamic spawnTimer is in fixedUpdate() based on BASE_SPAWN_RATE.
	iSetTimer(10, fixedUpdate);   // ~100 FPS


	iStart();
	return 0;
}

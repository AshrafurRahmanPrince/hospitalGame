void iDraw()
{
	iClear();

	if (currentScreen == SCREEN_MENU) { drawMenu(); return; }
	if (currentScreen == SCREEN_SETTINGS) { drawSettings(); return; }
	if (currentScreen == SCREEN_CREDITS) { drawCredits(); return; }
	if (currentScreen == SCREEN_PAUSE) { drawPause(); return; }

    // if we reach here, we are in GAME, or other in-game overlays
	// (keep your existing game drawing code below)

	// 1) Draw bgDark full screen
	iShowImage(0, 0, WIN_W, WIN_H, backgroundImage[currentRoom]);

	// movement check (for animation only)
    bool moving =
		isKeyDownChar('w') || isKeyDownChar('a') || isKeyDownChar('s') || isKeyDownChar('d') ||
		((GetAsyncKeyState(VK_UP) & 0x8000) != 0) || ((GetAsyncKeyState(VK_DOWN) & 0x8000) != 0) ||
		((GetAsyncKeyState(VK_LEFT) & 0x8000) != 0) || ((GetAsyncKeyState(VK_RIGHT) & 0x8000) != 0);

	if (moving && !gameOver)
	{
		// Animation now driven by fixedUpdate time-based timer (charFrameTimerMs)
		// Keep iDraw lightweight; frame progression happens in fixedUpdate.
	}
	else
	{
		charFrame = 0;
	}

	// player sprite (draw ONCE) - rotated to face mouse cursor

	// draw obstacles (before entities so they appear under entities)
	drawObstacles();

	// Editor overlay UI
	if (obstacleEditorActive)
	{
		drawEditorUI();

		// draw temp polygon if adding
		if (editorAdding && editorTempVx.size() > 0)
		{
			glEnable(GL_BLEND);
			glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
			glColor4f(1, 0, 0, 0.4f);
			glBegin(GL_POLYGON);
			for (size_t i = 0; i < editorTempVx.size(); i++) glVertex2d(editorTempVx[i], editorTempVy[i]);
			glEnd();
			glDisable(GL_BLEND);
		}

		// highlight selected
		if (editorSelected >= 0 && editorSelected < (int)roomObstacles[currentRoom].size())
		{
			const Obstacle &sel = roomObstacles[currentRoom][editorSelected];
			glColor3f(1,1,0);
			glBegin(GL_LINE_LOOP);
			for (size_t i = 0; i < sel.vx.size(); i++) glVertex2d(sel.vx[i], sel.vy[i]);
			glEnd();
		}
	}

	double viewAngleDegrees = viewAngle * (180.0 / 3.14159265359) - 90.0;
	glPushMatrix();
	glTranslatef(playerX + playerSize / 2.0f, playerY + playerSize / 2.0f, 0);
	glRotatef(viewAngleDegrees, 0, 0, 1);
	glTranslatef(-(playerSize / 2.0f), -(playerSize / 2.0f), 0);
	iShowImage(0, 0, playerSize, playerSize, charImg[charFrame]);
	glPopMatrix();

    // Torch cone (always active) - draw a soft warm cone in the facing direction
    {
        glEnable(GL_BLEND);
        glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
        // Warm soft light (RGBA) - low alpha so it acts like illumination, not opaque
        glColor4f(1.0f, 0.95f, 0.7f, 0.18f);

        double halfAngle = (torchAngleDeg * PI / 180.0) * 0.5;
        int segments = 36;
        double cx = playerX + playerSize / 2.0;
        double cy = playerY + playerSize / 2.0;

        glBegin(GL_TRIANGLE_FAN);
        glVertex2d(cx, cy);
        for (int s = 0; s <= segments; s++)
        {
            double t = (double)s / (double)segments;
            double ang = viewAngle - halfAngle + t * (2.0 * halfAngle);
            double vx = cx + cos(ang) * (double)torchRadius;
            double vy = cy + sin(ang) * (double)torchRadius;
            glVertex2d(vx, vy);
        }
        glEnd();

        // restore color/blend
        glColor4f(1.0f, 1.0f, 1.0f, 1.0f);
        glDisable(GL_BLEND);
    }

	// zombies
	for (int i = 0; i < zombiesSpawned; i++)
	{
		if (!zombieAlive[i]) continue;
		int imgIndex = i % 7;
		// rotate zombie to face its movement direction
		double angDeg = zombieAngle[i] * (180.0 / 3.14159265359) - 90.0;
		glPushMatrix();
		glTranslatef((GLfloat)(zombieX[i] + zombieSize[i] / 2.0), (GLfloat)(zombieY[i] + zombieSize[i] / 2.0), 0);
		glRotatef((GLfloat)angDeg, 0, 0, 1);
		glTranslatef((GLfloat)(-zombieSize[i] / 2.0), (GLfloat)(-zombieSize[i] / 2.0), 0);
		iShowImage(0, 0, zombieSize[i], zombieSize[i], zombieImg[imgIndex]);
		glPopMatrix();
